@page "/rooms/create"
@inject NavigationManager Navigation

<PageTitle>Add Room - Hotel System</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Add New Room</MudText>

<MudPaper Elevation="2" Class="pa-4">
    <MudForm @ref="form" @bind-IsValid="@success">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="newRoom.RoomNumber" Label="Room Number" Required="true"
                              RequiredError="Room number is required" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect @bind-Value="newRoom.RoomTypeID" Label="Room Type" Required="true" Variant="Variant.Outlined">
                    @foreach (var type in roomTypes)
                    {
                        <MudSelectItem Value="@type.RoomTypeID">@type.TypeName - $@type.PricePerNight/night</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudNumericField @bind-Value="newRoom.Floor" Label="Floor" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSwitch Value="IsRoomAvailable" ValueChanged="@((bool val) => { newRoom.IsAvailable = val; IsRoomAvailable = val; })" T="bool" Label="Available" Color="Color.Success" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="newRoom.Notes" Label="Notes" Lines="3" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-4" />

        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveRoom"
                   Disabled="@(!success)" Class="mr-2">Save Room</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="/rooms">Cancel</MudButton>
    </MudForm>
</MudPaper>

@code {
    private RoomCRUD roomCrud = new RoomCRUD();
    private RoomTypeCRUD roomTypeCrud = new RoomTypeCRUD();

    private Room newRoom = new Room { IsAvailable = true };
    private List<RoomType> roomTypes = new List<RoomType>();
    private MudForm form = null!;
    private bool success = false;
    private bool IsRoomAvailable { get; set; } = true;

    protected override void OnInitialized()
    {
        roomTypes = roomTypeCrud.GetAllRoomTypes();
    }

    private void SaveRoom()
    {
        try
        {
            // LINQ INSERT example
            roomCrud.CreateRoom(newRoom);
            Navigation.NavigateTo("/rooms");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating room: {ex.Message}");
        }
    }
}
