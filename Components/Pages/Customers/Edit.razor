@page "/customers/edit/{CustomerId:int}"
@inject NavigationManager Navigation

<PageTitle>Edit Customer - Hotel System</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Edit Customer</MudText>

@if (customer != null)
{
    <MudPaper Elevation="2" Class="pa-4">
        <MudForm @ref="form" @bind-IsValid="@success">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="customer.FirstName" Label="First Name" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="customer.LastName" Label="Last Name" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="customer.Email" Label="Email" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="customer.Phone" Label="Phone" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="customer.Address" Label="Address" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="customer.City" Label="City" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="customer.Country" Label="Country" Required="true" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />

            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="UpdateCustomer" Class="mr-2">Update Customer</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="/customers">Cancel</MudButton>
        </MudForm>
    </MudPaper>
}
else
{
    <MudAlert Severity="Severity.Error">Customer not found</MudAlert>
}

@code {
    [Parameter]
    public int CustomerId { get; set; }

    private CustomerCRUD customerCrud = new CustomerCRUD();
    private Customer? customer;
    private MudForm form = null!;
    private bool success = false;

    protected override void OnInitialized()
    {
        customer = customerCrud.GetCustomerById(CustomerId);
    }

    private void UpdateCustomer()
    {
        if (customer != null)
        {
            // LINQ UPDATE example
            customerCrud.UpdateCustomer(customer);
            Navigation.NavigateTo("/customers");
        }
    }
}
